# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=https://api.yonda.ng

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://yonda:password@localhost:5432/yonda_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Meta Cloud API (WhatsApp) ────────────────────────────────────────────────
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=your_random_verify_token_here
META_WHATSAPP_APP_SECRET=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxx

# ─── Encryption (BVN at-rest) ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Admin Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_DASHBOARD_URL=https://admin.yonda.ng
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Business Rules ───────────────────────────────────────────────────────────
MIN_CNY_AMOUNT=100
MAX_CNY_AMOUNT=50000
PAYMENT_LINK_TTL_HOURS=2
SESSION_TTL_SECONDS=86400
